{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "vamiga",
            "request": "launch",
            "name": "Launch vAmiga",
            "program": "${workspaceFolder}/simple_c.exe",
            "debugProgram": "${workspaceFolder}/simple_c.elf",
            "fastLoad": true,
            "stopOnEntry": true,
            "emulatorOptions": {
                "kickstartRomPath": "c:/amiga/kick13.rom",
                "chipRam": "512k",
                "slowRam": "512k",
                "fastRam": "0",
                "agnusRevision": "OCS",
                "deniseRevision": "OCS",
                "paulaRevision": "OCS",
                "blitterAccuracy": 2,
                "cpuRevision": "68000",
                "cpuSpeed": "7MHz"
            }
        }
    ]
}